generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  name      String
  email     String?
  role      UserRole
  createdAt DateTime @default(now())

  creatorProfile     CreatorProfile?
  campaigns          Campaign[]           @relation("BrandCampaigns")
  applications       Application[]        @relation("CreatorApplications")
  materialSubmissions MaterialSubmission[] @relation("CreatorMaterials")
  producedContents   ProducedContent[]    @relation("OperatorContents")
  contentClaims      ContentClaim[]       @relation("CreatorClaims")
  publishProofs      PublishProof[]       @relation("CreatorProofs")
  payments           Payment[]            @relation("CreatorPayments")
}

model CreatorProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  displayName    String
  location       String
  interests      String
  platforms      String
  followerCount  Int
  contentStyle   String
  contact        String?
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Campaign {
  id           String         @id @default(cuid())
  brandId      String
  title        String
  description  String
  requirements String
  rewardText   String
  platform     String         @default("小红书")
  category     String         @default("种草内容")
  quota        Int            @default(50)
  rewardAmount Float          @default(100)
  allowImageText Boolean       @default(true)
  allowVideo     Boolean       @default(true)
  imageTextBrief String        @default("查看品牌文案和拍摄要求，完成仿拍后提交照片和文案给品牌审核。")
  imageTextCopy  String        @default("请结合个人真实体验，发布一篇自然、真实的小红书图文笔记。")
  videoBrief     String        @default("查看拍摄要求后上传原始视频素材，由运营制作数字人/混剪内容。")
  videoCopy      String        @default("请领取平台制作完成的视频和文案后发布到小红书。")
  aiPrecheckStatus AiPrecheckStatus @default(not_connected)
  status       CampaignStatus @default(recruiting)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  brand        User               @relation("BrandCampaigns", fields: [brandId], references: [id])
  questions    CampaignQuestion[]
  applications Application[]
}

model CampaignQuestion {
  id         String   @id @default(cuid())
  campaignId String
  title      String
  required   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  campaign Campaign            @relation(fields: [campaignId], references: [id])
  answers  ApplicationAnswer[]
}

model Application {
  id              String            @id @default(cuid())
  campaignId      String
  creatorId       String
  name            String
  socialPlatform  String
  socialHandle    String
  followerCount   Int
  pitch           String
  selectedNoteType NoteType?
  status          ApplicationStatus @default(pending_brand_review)
  brandReviewNote String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  campaign            Campaign             @relation(fields: [campaignId], references: [id])
  creator             User                 @relation("CreatorApplications", fields: [creatorId], references: [id])
  answers             ApplicationAnswer[]
  materialSubmissions MaterialSubmission[]
  contentTasks        ContentTask[]
  producedContents    ProducedContent[]
  payment             Payment?
}

model ApplicationAnswer {
  id            String   @id @default(cuid())
  applicationId String
  questionId    String
  answer        String
  createdAt     DateTime @default(now())

  application Application      @relation(fields: [applicationId], references: [id])
  question    CampaignQuestion @relation(fields: [questionId], references: [id])
}

model MaterialSubmission {
  id                 String         @id @default(cuid())
  applicationId      String
  creatorId          String
  noteType           NoteType       @default(video)
  fileUrl            String
  description        String
  status             MaterialStatus @default(pending_operator_review)
  operatorReviewNote String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  application      Application       @relation(fields: [applicationId], references: [id])
  creator          User              @relation("CreatorMaterials", fields: [creatorId], references: [id])
  contentTask      ContentTask?
  producedContents ProducedContent[]
}

model ContentTask {
  id                   String            @id @default(cuid())
  applicationId        String
  materialSubmissionId String?           @unique
  operatorId           String?
  status               ContentTaskStatus @default(waiting)
  note                 String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  application        Application        @relation(fields: [applicationId], references: [id])
  materialSubmission MaterialSubmission? @relation(fields: [materialSubmissionId], references: [id])
}

model ProducedContent {
  id                   String        @id @default(cuid())
  applicationId        String
  materialSubmissionId String?
  operatorId           String?
  contentType          NoteType      @default(video)
  source               ContentSource @default(operator)
  fileUrl              String
  description          String
  status               ContentStatus @default(pending_brand_final_review)
  brandReviewNote      String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  application        Application        @relation(fields: [applicationId], references: [id])
  materialSubmission MaterialSubmission? @relation(fields: [materialSubmissionId], references: [id])
  operator           User?              @relation("OperatorContents", fields: [operatorId], references: [id])
  claim              ContentClaim?
  publishProof       PublishProof?
  payment            Payment?
}

model ContentClaim {
  id                String      @id @default(cuid())
  producedContentId String      @unique
  creatorId         String
  status            ClaimStatus @default(claimed)
  claimedAt         DateTime    @default(now())

  producedContent ProducedContent @relation(fields: [producedContentId], references: [id])
  creator         User            @relation("CreatorClaims", fields: [creatorId], references: [id])
}

model PublishProof {
  id                String      @id @default(cuid())
  producedContentId String      @unique
  creatorId         String
  postUrl           String
  screenshotUrl     String?
  note              String?
  status            ProofStatus @default(submitted)
  submittedAt       DateTime    @default(now())

  producedContent ProducedContent @relation(fields: [producedContentId], references: [id])
  creator         User            @relation("CreatorProofs", fields: [creatorId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  applicationId     String        @unique
  producedContentId String?       @unique
  creatorId         String
  amount            Float
  status            PaymentStatus @default(pending_review)
  note              String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  application     Application      @relation(fields: [applicationId], references: [id])
  producedContent ProducedContent? @relation(fields: [producedContentId], references: [id])
  creator         User             @relation("CreatorPayments", fields: [creatorId], references: [id])
}

enum UserRole {
  creator
  brand
  operator
}

enum CampaignStatus {
  draft
  published
  recruiting
  recruitment_closed
  content_production
  publishing
  settlement
  completed
}

enum AiPrecheckStatus {
  not_connected
  pending
  passed
  failed
}

enum ApplicationStatus {
  pending_brand_review
  approved
  rejected
}

enum NoteType {
  image_text
  video
}

enum ContentSource {
  creator
  operator
}

enum MaterialStatus {
  pending_operator_review
  approved
  rejected
}

enum ContentStatus {
  pending_brand_final_review
  approved
  rejected
}

enum ContentTaskStatus {
  waiting
  in_progress
  submitted
  completed
}

enum ClaimStatus {
  claimed
}

enum ProofStatus {
  submitted
}

enum PaymentStatus {
  pending_review
  reviewing
  confirmed
  paid
}
