# Edge Function 环境变量（在 Supabase Dashboard → Settings → Edge Functions → Secrets 配置）

# AI 模型（至少配置一个，否则默认返回 mock 数据）
DEEPSEEK_API_KEY=sk-...         # 推荐：https://platform.deepseek.com
QWEN_API_KEY=sk-...             # 备用：通义千问 https://dashscope.aliyuncs.com
OPENAI_API_KEY=sk-...           # 也可用 OpenAI 兼容接口

# 开发调试：设为 true 则跳过 AI 调用，返回 mock 数据
AI_MOCK_MODE=false

# 由 Supabase 自动注入，无需手动配置：
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
